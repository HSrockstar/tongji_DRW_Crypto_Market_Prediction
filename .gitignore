# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# 虚拟环境
.venv/
venv/
env/

# 密钥与本地配置
kaggle.json
.env

# Kaggle 大型原始数据，不提交到 GitHub
data/raw/train.parquet
data/raw/test.parquet
data/raw/drw-crypto-market-prediction.zip

